+++ ./src/conf_mode/service_tailscale.py	2026-04-23 12:25:45.345517125 +0000
@@ -0,0 +1,204 @@
+#!/usr/bin/env python3
+#
+# Copyright VyOS maintainers and contributors <maintainers@vyos.io>
+#
+# This program is free software; you can redistribute it and/or modify
+# it under the terms of the GNU General Public License version 2 or later as
+# published by the Free Software Foundation.
+#
+# This program is distributed in the hope that it will be useful,
+# but WITHOUT ANY WARRANTY; without even the implied warranty of
+# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the
+# GNU General Public License for more details.
+#
+# You should have received a copy of the GNU General Public License
+# along with this program.  If not, see <http://www.gnu.org/licenses/>.
+
+import json
+import pwd
+
+from ipaddress import ip_network
+from pathlib import Path
+from sys import exit
+
+from vyos.config import Config
+from vyos.template import render
+from vyos.utils.file import write_file
+from vyos.utils.process import call
+from vyos import ConfigError
+from vyos import airbag
+
+airbag.enable()
+
+base = ['service', 'tailscale']
+config_file = Path('/etc/tailscale/config.json')
+systemd_override = Path('/run/systemd/system/tailscaled.service.d/10-vyos.conf')
+systemd_service = 'tailscaled.service'
+tailscale_cli = Path('/usr/bin/tailscale')
+tailscaled_bin = Path('/usr/sbin/tailscaled')
+
+exit_node_routes = ('0.0.0.0/0', '::/0')
+
+
+def _listify(value) -> list[str]:
+    if value is None:
+        return []
+    if isinstance(value, list):
+        return value
+    return [value]
+
+
+def _normalized_routes(routes: list[str], advertise_exit_node: bool) -> list[str]:
+    normalized: list[str] = []
+    seen: set[str] = set()
+
+    for route in routes:
+        prefix = str(ip_network(route, strict=False))
+        if prefix not in seen:
+            normalized.append(prefix)
+            seen.add(prefix)
+
+    if advertise_exit_node:
+        for route in exit_node_routes:
+            if route not in seen:
+                normalized.append(route)
+                seen.add(route)
+
+    return normalized
+
+
+def _build_config(tailscale: dict) -> dict:
+    config = {
+        'version': 'alpha0',
+        'locked': True,
+        'enabled': 'disable' not in tailscale,
+    }
+
+    if 'accept_dns' in tailscale:
+        config['acceptDNS'] = tailscale['accept_dns'] == 'enable'
+
+    if 'accept_routes' in tailscale:
+        config['acceptRoutes'] = True
+
+    if 'auth_key_file' in tailscale:
+        config['authKey'] = f'file:{tailscale["auth_key_file"]}'
+
+    if 'disable_snat' in tailscale:
+        config['disableSNAT'] = True
+
+    if 'exit_node' in tailscale:
+        config['exitNode'] = tailscale['exit_node']
+
+    if 'exit_node_allow_lan_access' in tailscale:
+        config['allowLANWhileUsingExitNode'] = True
+
+    if 'hostname' in tailscale:
+        config['hostname'] = tailscale['hostname']
+
+    if 'login_server' in tailscale:
+        config['serverURL'] = tailscale['login_server']
+
+    if 'netfilter_mode' in tailscale:
+        config['netfilterMode'] = tailscale['netfilter_mode']
+
+    if 'operator' in tailscale:
+        config['operatorUser'] = tailscale['operator']
+
+    if 'shields_up' in tailscale:
+        config['shieldsUp'] = True
+
+    if 'ssh' in tailscale:
+        config['runSSHServer'] = True
+
+    if 'webclient' in tailscale:
+        config['runWebClient'] = True
+
+    routes = _normalized_routes(
+        _listify(tailscale.get('advertise_routes')),
+        'advertise_exit_node' in tailscale,
+    )
+    if routes:
+        config['advertiseRoutes'] = routes
+
+    return config
+
+
+def get_config(config=None):
+    conf = config if config else Config()
+
+    if not conf.exists(base):
+        return None
+
+    tailscale = conf.get_config_dict(
+        base,
+        key_mangling=('-', '_'),
+        get_first_key=True,
+        no_tag_node_value_mangle=True,
+    )
+
+    tailscale['config_file'] = str(config_file)
+    tailscale['systemd_override'] = str(systemd_override)
+
+    return tailscale
+
+
+def verify(tailscale):
+    if tailscale is None:
+        return None
+
+    if not tailscale_cli.exists() or not tailscaled_bin.exists():
+        raise ConfigError('Tailscale package is not installed')
+
+    if 'operator' in tailscale:
+        try:
+            pwd.getpwnam(tailscale['operator'])
+        except KeyError as e:
+            raise ConfigError(
+                f'operator user "{tailscale["operator"]}" does not exist'
+            ) from e
+
+    if 'exit_node_allow_lan_access' in tailscale and 'exit_node' not in tailscale:
+        raise ConfigError(
+            'exit-node-allow-lan-access requires exit-node to be configured'
+        )
+
+    if 'disable_snat' in tailscale and 'advertise_routes' not in tailscale:
+        raise ConfigError('disable-snat requires advertise-routes to be configured')
+
+    return None
+
+
+def generate(tailscale):
+    if tailscale is None:
+        config_file.unlink(missing_ok=True)
+        systemd_override.unlink(missing_ok=True)
+        return None
+
+    config = _build_config(tailscale)
+    config_json = json.dumps(config, indent=2) + '\n'
+    write_file(str(config_file), config_json, mode=0o600)
+    render(str(systemd_override), 'tailscale/override.conf.j2', tailscale)
+
+    return None
+
+
+def apply(tailscale):
+    call('systemctl daemon-reload')
+
+    if tailscale is None or 'disable' in tailscale:
+        call(f'systemctl stop {systemd_service}')
+    else:
+        call(f'systemctl restart {systemd_service}')
+
+    return None
+
+
+if __name__ == '__main__':
+    try:
+        c = get_config()
+        verify(c)
+        generate(c)
+        apply(c)
+    except ConfigError as e:
+        print(e)
+        exit(1)
