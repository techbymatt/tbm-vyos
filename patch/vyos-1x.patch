+#!/usr/bin/env python3
+#
+# Copyright VyOS maintainers and contributors <maintainers@vyos.io>
+#
+# This program is free software; you can redistribute it and/or modify
+# it under the terms of the GNU General Public License version 2 or later as
+# published by the Free Software Foundation.
+#
+# This program is distributed in the hope that it will be useful,
+# but WITHOUT ANY WARRANTY; without even the implied warranty of
+# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+# GNU General Public License for more details.
+#
+# You should have received a copy of the GNU General Public License
+# along with this program.  If not, see <http://www.gnu.org/licenses/>.
+
+import json
+import sys
+
+import vyos.opmode
+
+from vyos.configquery import ConfigTreeQuery
+from vyos.utils.process import cmd
+
+service_path = ['service', 'tailscale']
+systemd_service = 'tailscaled.service'
+
+
+def _run_command(command: list[str]) -> str:
+    try:
+        return cmd(command, raising=vyos.opmode.InternalError)
+    except OSError as e:
+        raise vyos.opmode.InternalError(str(e)) from e
+
+
+def _run_json(command: list[str]) -> dict:
+    output = _run_command(command)
+    try:
+        return json.loads(output)
+    except json.JSONDecodeError as e:
+        raise vyos.opmode.InternalError(
+            f'Invalid JSON output from {" ".join(command)}: {e}'
+        ) from e
+
+
+def _verify_service_enabled() -> None:
+    config = ConfigTreeQuery()
+
+    if not config.exists(service_path):
+        raise vyos.opmode.UnconfiguredSubsystem('Tailscale service is not configured')
+
+    if config.exists(service_path + ['disable']):
+        raise vyos.opmode.UnconfiguredSubsystem('Tailscale service is disabled')
+
+
+def show_status(raw: bool):
+    if raw:
+        return _run_json(['tailscale', 'status', '--json'])
+
+    return _run_command(['tailscale', 'status'])
+
+
+def show_prefs(raw: bool):
+    if raw:
+        return _run_json(['tailscale', 'debug', 'prefs'])
+
+    return _run_command(['tailscale', 'debug', 'prefs'])
+
+
+def restart_client():
+    _verify_service_enabled()
+    _run_command(['systemctl', 'restart', systemd_service])
+
+
+def set_connect():
+    _verify_service_enabled()
+    _run_command(['systemctl', 'start', systemd_service])
+
+
+def set_disconnect():
+    _verify_service_enabled()
+    _run_command(['systemctl', 'stop', systemd_service])
+
+
+if __name__ == '__main__':
+    try:
+        res = vyos.opmode.run(sys.modules[__name__])
+        if res:
+            print(res)
+    except (ValueError, vyos.opmode.Error) as e:
+        print(e)
+        sys.exit(1)
