+# along with this program.  If not, see <http://www.gnu.org/licenses/>.
+
+import json
+import os
+import unittest
+
+from base_vyostest_shim import VyOSUnitTestSHIM
+
+from vyos.utils.file import read_file
+from vyos.utils.process import is_systemd_service_active
+from vyos.utils.process import process_named_running
+
+TAILSCALE_BIN = '/usr/bin/tailscale'
+TAILSCALED_BIN = '/usr/sbin/tailscaled'
+TAILSCALE_SERVICE = 'tailscaled.service'
+TAILSCALED_CONFIG = '/etc/tailscale/config.json'
+TAILSCALED_OVERRIDE = '/run/systemd/system/tailscaled.service.d/10-vyos.conf'
+TAILSCALED_PROCESS = 'tailscaled'
+TAILSCALED_CMDLINE = '--state=/var/lib/tailscale/tailscaled.state'
+
+base_path = ['service', 'tailscale']
+
+
+class TestServiceTailscale(VyOSUnitTestSHIM.TestCase):
+    @classmethod
+    def setUpClass(cls):
+        super(TestServiceTailscale, cls).setUpClass()
+
+        if not os.path.exists(TAILSCALE_BIN) or not os.path.exists(TAILSCALED_BIN):
+            raise AssertionError('Tailscale package is not installed')
+
+        cls.cli_delete(cls, base_path)
+
+    def tearDown(self):
+        self.cli_delete(base_path)
+        self.cli_commit()
+        super().tearDown()
+
+    def test_01_tailscale_client_cli(self):
+        hostname = 'vyos-tailscale'
+        operator = 'vyos'
+        login_server = 'https://headscale.example.com'
+        advertise_routes = ['192.0.2.0/24', '2001:db8::/64']
+        expected_routes = advertise_routes + ['0.0.0.0/0', '::/0']
+
+        self.cli_set(base_path + ['accept-dns', 'disable'])
+        self.cli_set(base_path + ['accept-routes'])
+        self.cli_set(base_path + ['advertise-exit-node'])
+        for route in advertise_routes:
+            self.cli_set(base_path + ['advertise-routes', route])
+        self.cli_set(base_path + ['disable-snat'])
+        self.cli_set(base_path + ['hostname', hostname])
+        self.cli_set(base_path + ['login-server', login_server])
+        self.cli_set(base_path + ['netfilter-mode', 'nodivert'])
+        self.cli_set(base_path + ['operator', operator])
+        self.cli_set(base_path + ['shields-up'])
+        self.cli_set(base_path + ['ssh'])
+        self.cli_set(base_path + ['webclient'])
+
+        self.cli_commit()
+
+        self.assertTrue(is_systemd_service_active(TAILSCALE_SERVICE))
+
+        current_pid = process_named_running(
+            TAILSCALED_PROCESS, TAILSCALED_CMDLINE, timeout=10
+        )
+        self.assertIsNotNone(current_pid)
+
+        config = json.loads(read_file(TAILSCALED_CONFIG))
+        self.assertEqual(config['version'], 'alpha0')
+        self.assertTrue(config['locked'])
+        self.assertTrue(config['enabled'])
+        self.assertFalse(config['acceptDNS'])
+        self.assertTrue(config['acceptRoutes'])
+        self.assertEqual(config['hostname'], hostname)
+        self.assertEqual(config['operatorUser'], operator)
+        self.assertEqual(config['serverURL'], login_server)
+        self.assertEqual(config['netfilterMode'], 'nodivert')
+        self.assertTrue(config['disableSNAT'])
+        self.assertTrue(config['runSSHServer'])
+        self.assertTrue(config['runWebClient'])
+        self.assertTrue(config['shieldsUp'])
+        self.assertEqual(sorted(config['advertiseRoutes']), sorted(expected_routes))
+
+        override = read_file(TAILSCALED_OVERRIDE)
+        self.assertIn(f'ConditionPathExists={TAILSCALED_CONFIG}', override)
+        self.assertIn(f'--config={TAILSCALED_CONFIG}', override)
+
+        status_text = self.op_mode(['show', 'tailscale'])
+        self.assertNotEqual(status_text, '')
+
+        prefs_text = self.op_mode(['show', 'tailscale', 'prefs'])
+        self.assertIn('ControlURL', prefs_text)
+
+        status_json = json.loads(self.op_mode(['show', 'tailscale', 'status', 'json']))
+        self.assertIn('backend_state', status_json)
+
+        prefs_json = json.loads(self.op_mode(['show', 'tailscale', 'prefs', 'json']))
+        self.assertEqual(prefs_json['control_url'], login_server)
+        self.assertFalse(prefs_json['corp_dns'])
+        self.assertTrue(prefs_json['route_all'])
+        self.assertEqual(
+            sorted(prefs_json['advertise_routes']), sorted(expected_routes)
+        )
+        self.assertTrue(prefs_json['no_snat'])
+        self.assertEqual(prefs_json['netfilter_mode'], 'nodivert')
+        self.assertEqual(prefs_json['hostname'], hostname)
+        self.assertEqual(prefs_json['operator_user'], operator)
+        self.assertTrue(prefs_json['run_ssh'])
+        self.assertTrue(prefs_json['run_web_client'])
+        self.assertTrue(prefs_json['shields_up'])
+        self.assertTrue(prefs_json['want_running'])
+
+        self.op_mode(['execute', 'tailscale', 'down'])
+        self.assertFalse(is_systemd_service_active(TAILSCALE_SERVICE))
+        self.assertIsNone(process_named_running(TAILSCALED_PROCESS, TAILSCALED_CMDLINE))
+
+        self.op_mode(['execute', 'tailscale', 'up'])
+        self.assertTrue(is_systemd_service_active(TAILSCALE_SERVICE))
+
+        reconnected_pid = process_named_running(
+            TAILSCALED_PROCESS, TAILSCALED_CMDLINE, timeout=10
+        )
+        self.assertIsNotNone(reconnected_pid)
+
+        self.op_mode(['restart', 'tailscale'])
+
+        restarted_pid = process_named_running(
+            TAILSCALED_PROCESS, TAILSCALED_CMDLINE, timeout=10
+        )
+        self.assertIsNotNone(restarted_pid)
+        self.assertNotEqual(reconnected_pid, restarted_pid)
+
+
+if __name__ == '__main__':
+    unittest.main(verbosity=2, failfast=VyOSUnitTestSHIM.TestCase.debug_on())
